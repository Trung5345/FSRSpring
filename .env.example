APP_HOST_PORT=8080
PORT=8080
APP_FRONTEND_BASE_URL=http://localhost:3000

# Database
MYSQL_HOST_PORT=3307
MYSQL_DATABASE=fsrspring
MYSQL_USER=fsr_user
MYSQL_PASSWORD=fsr_pass
MYSQL_ROOT_PASSWORD=rootpass

# Spring datasource env vars (matched to application.properties)
MYSQL_USERNAME=fsr_user
MYSQL_URL=jdbc:mysql://localhost:3307/fsrspring?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC&characterEncoding=UTF-8&useUnicode=true
JPA_DDL_AUTO=update
SQL_INIT_MODE=never

# Redis & Session
REDISHOST=localhost
REDISPORT=6379
REDISPASSWORD=fsr_redis_pass_123
REDIS_URL=redis://:fsr_redis_pass_123@localhost:6379/0
SESSION_STORE_TYPE=redis

# APIs
APP_API_LIBRETRANSLATE_BASE_URL=http://localhost:5000
APP_API_WIKTAPI_BASE_URL=https://api.wiktapi.dev
APP_API_PIXABAY_KEY=
APP_API_PEXELS_KEY=
YOUTUBE_API_KEY=
NEWS_API_KEY=

# Enrichment runtime
APP_ENRICHMENT_ENABLED=true
APP_ENRICHMENT_IMAGE_STORAGE_DIR=data/enrichment-images
APP_ENRICHMENT_IMAGE_PUBLIC_PREFIX=/generated-images/
APP_ENRICHMENT_POLL_DELAY_MS=10000

# Mail & Reminders
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=false
MAIL_SMTP_STARTTLS=false
DEFAULT_REMINDER_EMAIL=learner@example.com

# OAuth2 Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# JWT auth for local API login
JWT_SECRET=
JWT_ACCESS_TOKEN_EXPIRATION_MS=900000
JWT_REFRESH_TOKEN_EXPIRATION_MS=604800000
